@model IEnumerable<AiDebugCoach.Models.ViewModels.BugReportViewModel>

@{
    ViewData["Title"] = "AI Debug Coach";
}

<div class="container-fluid mt-4">
    <div class="row g-4">
        <main class="col-lg-8">
            <div class="card p-4">
                @if (ViewBag.SelectedReport != null)
                {
                    var r = (AiDebugCoach.Models.ViewModels.BugReportViewModel)ViewBag.SelectedReport;
                    var analysis = r.Analysis;

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="mb-0">Analysis Details</h4>
                        <a href="/" class="btn btn-outline-secondary btn-sm">New Analysis</a>
                    </div>

                    <div class="mb-4">
                        <span class="text-muted">Error</span>
                        <p class="fw-bold">@r.ErrorMessage</p>
                    </div>

                    <pre><code>@r.Code</code></pre>

                    @if (analysis != null)
                    {
                        <hr class="my-4"/>
                        <h5 class="text-primary">AI Insights</h5>
                        <p><strong>Cause:</strong> @analysis.Cause</p>
                        <p><strong>Explanation:</strong> @analysis.Explanation</p>

                        <h6 class="mt-3">Fix Steps:</h6>
                        <ol class="list-group list-group-numbered mb-3">
                            @foreach (var step in analysis.FixSteps)
                            {
                                <li class="list-group-item border-0">@step</li>
                            }
                        </ol>

                        <h6 class="mt-3">Code Example:</h6>
                        <pre><code>@analysis.CodeExamples</code></pre>
                    }
                }
                else
                {
                    <h4 class="mb-3">New Analysis</h4>
                    <form id="analysisForm">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Code</label>
                            <textarea name="code" class="form-control" rows="8" placeholder="Paste your code..."
                                      required></textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Error Message</label>
                            <textarea name="errorMessage" class="form-control" rows="2" placeholder="What went wrong?"
                                      required></textarea>
                        </div>
                        <button type="submit" id="analyzeBtn" class="btn btn-primary w-100 btn-lg">
                            <span id="btnText">Analyze with AI</span>
                        </button>
                    </form>
                    <div id="resultContainer" class="mt-4"></div>
                }
            </div>
        </main>

        <aside class="col-lg-4">
            <div class="card sidebar-container">
                <div class="card-header">
                    <h5 class="mb-0">History</h5>
                </div>
                <div class="scroll-area">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <a asp-action="Index" asp-route-id="@item.Id"
                               class="list-group-item list-group-item-action history-item border-0 p-3">
                                <small class="text-muted d-block">@item.FormattedDate</small>
                                <p class="mb-0 text-truncate fw-medium text-dark">@item.ErrorMessage</p>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">No history found.</div>
                    }
                </div>
            </div>
        </aside>
    </div>
</div>

<script>
    const form = document.getElementById('analysisForm');
    const btn = document.getElementById('analyzeBtn');
    const btnText = document.getElementById('btnText');
    const resultContainer = document.getElementById('resultContainer');

    form?.addEventListener('submit', async function (e) {
        e.preventDefault();
        btn.disabled = true;
        btnText.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Thinking...';

        try {
            const response = await fetch('/Home/Analyze', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    code: form.querySelector('[name="code"]').value,
                    errorMessage: form.querySelector('[name="errorMessage"]').value
                })
            });

            if (!response.ok) throw new Error(await response.text() || "Failed to analyze.");

            const data = await response.json();
            const res = data.result;

            const fixHtml = res.fixSteps.map(s => `<li class="list-group-item border-0">${s}</li>`).join('');

            resultContainer.innerHTML = `
                <div class="alert alert-success">Analysis complete!</div>
                <h5 class="text-primary">Result</h5>
                <p><strong>Cause:</strong> ${res.cause}</p>
                <p><strong>Explanation:</strong> ${res.explanation}</p>
                <h6>Fix Steps:</h6>
                <ol class="list-group list-group-numbered mb-3">${fixHtml}</ol>
                <pre><code>${res.codeExamples}</code></pre>
                <a href="/" class="btn btn-outline-primary mt-3">Analyze Another</a>
            `;
        } catch (err) {
            alert(err.message);
        } finally {
            btn.disabled = false;
            btnText.innerText = 'Analyze with AI';
        }
    });
</script>