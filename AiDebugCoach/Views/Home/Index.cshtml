@model List<AiDebugCoach.Models.BugReport>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container my-3" style="max-width: 800px;">
    <div class="card shadow-sm p-3 mb-4 bg-white rounded border">
        <h4 class="mb-3 text-primary">AI Debug Coach</h4>
        <form method="post" asp-action="Analyze">
            <div class="mb-2">
                <label class="form-label small fw-bold">Paste Code</label>
                <textarea name="code" class="form-control form-control-sm" rows="4"
                          placeholder="Paste your code here..."></textarea>
            </div>

            <div class="mb-2">
                <label class="form-label small fw-bold">Error Message</label>
                <textarea name="errorMessage" class="form-control form-control-sm" rows="2"
                          placeholder="What went wrong?"></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-sm mt-1">Analyze</button>
        </form>
    </div>

    <div class="container my-3" style="max-width: 800px;">
        <h5 class="mb-3">Previous Debugs</h5>

        @foreach (var item in Model)
        {
            // One clean line to get the data
            var analysis = item.GetAnalysis();

            <div class="card mb-4 shadow-sm border-0 rounded-3 overflow-hidden">
                <div class="card-header bg-light border-0 d-flex justify-content-between align-items-center py-2 px-3">
                    <span class="text-muted small fw-bold">@item.CreatedAt.ToString("g")</span>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                          onsubmit="return confirm('Delete?');">
                        <button type="submit" class="btn btn-sm btn-outline-danger border-0">Delete</button>
                    </form>
                </div>

                <div class="card-body p-3">
                    <div class="mb-3 border-bottom pb-2">
                        <h6 class="text-uppercase text-secondary small fw-bold mb-1">Problem</h6>
                        <div class="alert alert-secondary py-1 px-2 small mb-2">@item.ErrorMessage</div>
                        <pre class="bg-dark text-light p-3 rounded small"><code>@item.Code</code></pre>
                    </div>

                    @if (analysis != null)
                    {
                        <div class="mb-3">
                            <h6 class="text-uppercase text-primary small fw-bold mb-1">Root Cause</h6>
                            <p class="text-dark mb-3">@analysis.Cause</p>
                        </div>

                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <h6 class="text-uppercase text-success small fw-bold mb-1">Suggested Fix</h6>
                            <div class="ai-response-text text-success-emphasis">@analysis.Fix</div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
    document.querySelectorAll('.ai-response-text').forEach(el => {
        el.innerHTML = marked.parse(el.innerText);
    });
</script>
