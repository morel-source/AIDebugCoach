@model IEnumerable<AiDebugCoach.Models.BugReport>

<div class="card shadow-sm">
    <div class="card-header bg-light">
        <h5 class="mb-0">Previous Debugs</h5>
    </div>
    <div class="list-group list-group-flush" style="max-height: 75vh; overflow-y: auto;">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model.OrderByDescending(x => x.CreatedAt))
            {
                <a asp-action="Details" asp-route-id="@item.Id" 
                   class="list-group-item list-group-item-action d-flex justify-content-between align-items-start p-3">
                    <div>
                        <small class="text-muted d-block">@item.CreatedAt.ToString("MMM dd, HH:mm")</small>
                        <p class="mb-0 text-truncate" style="max-width: 200px;">@item.ErrorMessage</p>
                    </div>
                </a>
            }
        }
    </div>
</div>